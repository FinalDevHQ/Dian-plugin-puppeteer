{
  "name": "dian-plugin-puppeteer",
  "version": "1.0.1",
  "description": "Dian Puppeteer 渲染服务插件 - 提供 HTML/模板截图渲染 API",
  "type": "module",
  "scripts": {
    "build": "tsup && vite build --config ui/vite.config.ts",
    "dev": "tsup --watch",
    "dev:ui": "vite --config ui/vite.config.ts",
    "pack": "npm run build && node scripts/pack.mjs"
  },
  "dependencies": {
    "@myfinal/plugin-runtime": "^0.2.7",
    "@myfinal/shared": "^0.2.1",
    "puppeteer-core": "^24.4.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "fflate": "^0.8.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.10",
    "ws": "^8.18.2"
  }
}
